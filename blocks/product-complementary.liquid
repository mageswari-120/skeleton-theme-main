{%- comment -%}
  Block: product-complementary
  Shows hand-picked complementary products as compact cards.
{%- endcomment -%}

{%- liquid
  assign products = block.settings.products
  assign limit = block.settings.limit | default: 4
-%}

<div class="complementary" {{ block.shopify_attributes }}>
  {%- if block.settings.heading != blank -%}
    <p class="complementary__heading">{{ block.settings.heading | escape }}</p>
  {%- endif -%}

  {%- if products.count > 0 -%}
    <ul class="complementary__list" role="list">
      {%- for item in products limit: limit -%}
        <li class="complementary__card">
          <a class="complementary__media" href="{{ item.url }}">
            {%- if item.featured_image -%}
              {{ item.featured_image | image_url: width: 160 | image_tag: loading: 'lazy', width: 80, height: 80, alt: item.featured_image.alt | escape | default: item.title }}
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: 'complementary__placeholder' }}
            {%- endif -%}
          </a>
          <div class="complementary__info">
            <a class="complementary__title" href="{{ item.url }}">{{ item.title | escape }}</a>
            {% render 'price', product: item, show_badge: false %}
          </div>
        </li>
      {%- endfor -%}
    </ul>
  {%- else -%}
    <p class="complementary__empty">Select complementary products in the block settings.</p>
  {%- endif -%}
</div>

{% stylesheet %}
  .complementary__heading { font-weight: 600; margin: 0 0 8px; }
  .complementary__list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 10px; }
  .complementary__card { display: flex; gap: 12px; align-items: center; }
  .complementary__media { flex: 0 0 auto; width: 56px; height: 56px; border-radius: 6px; overflow: hidden; }
  .complementary__media img,
  .complementary__placeholder { width: 56px; height: 56px; object-fit: cover; }
  .complementary__info { min-width: 0; }
  .complementary__title { display: block; font-size: 0.85rem; color: inherit; text-decoration: none; }
  .complementary__title:hover { text-decoration: underline; }
  .complementary .price { font-size: 0.85rem; }
  .complementary__empty { opacity: 0.7; font-size: 0.85rem; margin: 0; }
{% endstylesheet %}

{% schema %}
{
  "name": "Complementary products",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Pairs well with" },
    { "type": "product_list", "id": "products", "label": "Products", "limit": 8 },
    { "type": "range", "id": "limit", "label": "Products to show", "min": 1, "max": 8, "step": 1, "default": 4 }
  ],
  "presets": [
    { "name": "Complementary products" }
  ]
}
{% endschema %}
