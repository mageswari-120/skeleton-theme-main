{%- comment -%}
  Block: product-share
  Social share buttons + copy link (Web Share API where available).
{%- endcomment -%}

{%- liquid
  assign p = block.settings.product
  assign share_url = p.url | default: request.path | prepend: request.origin
-%}

<product-share class="product-share" data-url="{{ share_url }}" data-title="{{ p.title | escape }}" {{ block.shopify_attributes }}>
  {%- if block.settings.label != blank -%}
    <span class="product-share__label">{{ block.settings.label | escape }}</span>
  {%- endif -%}
  <div class="product-share__buttons">
    <button type="button" class="product-share__btn" data-native-share aria-label="Share" hidden>
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><path d="M8.6 13.5l6.8 4M15.4 6.5l-6.8 4"/></svg>
    </button>
    <a class="product-share__btn" href="https://www.facebook.com/sharer/sharer.php?u={{ share_url | url_encode }}" target="_blank" rel="noopener" aria-label="Share on Facebook">f</a>
    <a class="product-share__btn" href="https://twitter.com/intent/tweet?url={{ share_url | url_encode }}&text={{ p.title | url_encode }}" target="_blank" rel="noopener" aria-label="Share on X">X</a>
    <a class="product-share__btn" href="https://pinterest.com/pin/create/button/?url={{ share_url | url_encode }}&description={{ p.title | url_encode }}" target="_blank" rel="noopener" aria-label="Share on Pinterest">P</a>
    <button type="button" class="product-share__btn" data-copy-link aria-label="Copy link">
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 0 0 7 0l3-3a5 5 0 0 0-7-7l-1 1"/><path d="M14 11a5 5 0 0 0-7 0l-3 3a5 5 0 0 0 7 7l1-1"/></svg>
    </button>
  </div>
  <span class="product-share__copied" data-copied hidden>Link copied</span>
</product-share>

{% stylesheet %}
  .product-share { display: flex; align-items: center; gap: 10px; font-size: 0.85rem; flex-wrap: wrap; }
  .product-share__buttons { display: flex; gap: 6px; }
  .product-share__btn {
    width: 34px; height: 34px; border: 1px solid #d1d5db; border-radius: 50%;
    display: inline-flex; align-items: center; justify-content: center; cursor: pointer;
    background: #fff; color: inherit; text-decoration: none; font-size: 0.8rem;
  }
  .product-share__btn:hover { border-color: var(--color-foreground); }
  .product-share__copied { color: #16a34a; }
{% endstylesheet %}

{% javascript %}
  if (!customElements.get('product-share')) {
    customElements.define('product-share', class extends HTMLElement {
      connectedCallback() {
        this.url = this.dataset.url;
        this.title = this.dataset.title;
        const nativeBtn = this.querySelector('[data-native-share]');
        if (nativeBtn && navigator.share) {
          nativeBtn.hidden = false;
          nativeBtn.addEventListener('click', () => {
            navigator.share({ title: this.title, url: this.url }).catch(() => {});
          });
        }
        const copyBtn = this.querySelector('[data-copy-link]');
        const copied = this.querySelector('[data-copied]');
        if (copyBtn) {
          copyBtn.addEventListener('click', async () => {
            try {
              await navigator.clipboard.writeText(this.url);
              if (copied) {
                copied.hidden = false;
                clearTimeout(this._t);
                this._t = setTimeout(() => { copied.hidden = true; }, 2000);
              }
            } catch (e) { /* no-op */ }
          });
        }
      }
    });
  }
{% endjavascript %}

{% schema %}
{
  "name": "Share",
  "settings": [
    { "type": "product", "id": "product", "label": "Product" },
    { "type": "text", "id": "label", "label": "Label", "default": "Share:" }
  ],
  "presets": [
    { "name": "Share", "settings": { "product": "{{ closest.product }}" } }
  ]
}
{% endschema %}
