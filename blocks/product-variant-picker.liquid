{%- comment -%}
  Block: product-variant-picker
  Renders one group per product option. <product-context> reads the
  selected values (via [data-option-position] / [data-variant-option])
  and resolves the matching variant.

  Options named "Size" use the size picker type; all others use the
  swatch type.
{%- endcomment -%}

{%- liquid
  assign p = block.settings.product
  assign swatch_type = block.settings.swatch_type | default: 'color'
  assign size_type = block.settings.size_type | default: 'pill'
  assign shape = block.settings.swatch_shape | default: 'circle'
  assign size_px = block.settings.swatch_size | default: 28
  assign unavailable = block.settings.unavailable | default: 'strikethrough'
-%}

<variant-picker
  class="variant-picker variant-picker--{{ shape }} variant-picker--unavailable-{{ unavailable }}"
  style="--vp-size: {{ size_px }}px;"
  {{ block.shopify_attributes }}
>
  {%- if p == blank or p.has_only_default_variant -%}
    {%- comment -%} nothing to pick {%- endcomment -%}
  {%- else -%}
    {%- for option in p.options_with_values -%}
      {%- liquid
        assign opt_index = option.position | minus: 1
        assign nlow = option.name | downcase
        assign is_size = false
        if nlow contains 'size'
          assign is_size = true
        endif
        assign control = swatch_type
        if is_size
          assign control = size_type
        endif
      -%}

      <fieldset class="variant-picker__option" data-option-position="{{ option.position }}">
        <legend class="variant-picker__label">
          {{ option.name }}:
          {%- if block.settings.show_selected_label -%}
            <span class="variant-picker__selected" data-selected-value="{{ option.position }}">{{ option.selected_value }}</span>
          {%- endif -%}
        </legend>

        {%- if is_size and block.settings.show_size_guide and block.settings.size_guide_url != blank -%}
          <a class="variant-picker__size-guide" href="{{ block.settings.size_guide_url }}">{{ 'Size guide' }}</a>
        {%- endif -%}

        {%- if control == 'dropdown' -%}
          <select class="variant-picker__select" data-variant-option name="option-{{ option.position }}" aria-label="{{ option.name }}">
            {%- for value in option.values -%}
              {%- assign vname = value.name | default: value -%}
              {%- assign val_available = false -%}
              {%- for v in p.variants -%}
                {%- if v.options[opt_index] == vname and v.available -%}{%- assign val_available = true -%}{%- break -%}{%- endif -%}
              {%- endfor -%}
              <option value="{{ vname | escape }}" {% if option.selected_value == vname %}selected{% endif %} {% unless val_available %}data-unavailable{% endunless %}>{{ vname }}{% unless val_available %} – unavailable{% endunless %}</option>
            {%- endfor -%}
          </select>
        {%- else -%}
          <div class="variant-picker__values variant-picker__values--{{ control }}">
            {%- for value in option.values -%}
              {%- liquid
                assign vname = value.name | default: value
                assign val_available = false
                for v in p.variants
                  if v.options[opt_index] == vname and v.available
                    assign val_available = true
                    break
                  endif
                endfor
                assign input_id = block.id | append: '-' | append: option.position | append: '-' | append: forloop.index0
                assign vname_esc = vname | escape
              -%}
              <input
                type="radio"
                class="variant-picker__input"
                data-variant-option
                id="{{ input_id }}"
                name="option-{{ block.id }}-{{ option.position }}"
                value="{{ vname | escape }}"
                {% if option.selected_value == vname %}checked{% endif %}
                {% unless val_available %}data-unavailable{% endunless %}
              >
              <label
                class="variant-picker__swatch variant-picker__swatch--{{ control }}{% unless val_available %} is-unavailable{% endunless %}"
                for="{{ input_id }}"
                {% if control == 'color' and value.swatch.color %}style="--vp-swatch: {{ value.swatch.color }};"{% endif %}
                title="{{ vname | escape }}"
              >
                {%- if control == 'image' and value.swatch.image -%}
                  {{ value.swatch.image | image_url: width: 64 | image_tag: loading: 'lazy', alt: vname_esc, width: 32, height: 32 }}
                {%- elsif control == 'color' -%}
                  <span class="visually-hidden">{{ vname }}</span>
                {%- else -%}
                  {{ vname }}
                {%- endif -%}
              </label>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </fieldset>
    {%- endfor -%}
  {%- endif -%}
</variant-picker>

{% stylesheet %}
  .variant-picker { display: flex; flex-direction: column; gap: 14px; }
  .variant-picker__option { border: 0; padding: 0; margin: 0; position: relative; }
  .variant-picker__label { font-size: 0.85rem; font-weight: 600; padding: 0; margin-bottom: 8px; }
  .variant-picker__selected { font-weight: 400; opacity: 0.8; }
  .variant-picker__size-guide { position: absolute; top: 0; right: 0; font-size: 0.8rem; }

  .variant-picker__values { display: flex; flex-wrap: wrap; gap: 8px; }
  .variant-picker__input { position: absolute; opacity: 0; pointer-events: none; }

  .variant-picker__swatch {
    display: inline-flex; align-items: center; justify-content: center;
    min-width: var(--vp-size, 28px); height: var(--vp-size, 28px); padding: 0 4px;
    border: 1px solid #d1d5db; cursor: pointer; user-select: none; overflow: hidden;
    background: #fff; font-size: 0.85rem;
  }
  .variant-picker__swatch--color { width: var(--vp-size, 28px); background: var(--vp-swatch, #ccc); }
  .variant-picker__swatch--pill { padding: 0 14px; height: auto; min-height: 36px; }
  .variant-picker__swatch--image img { width: 100%; height: 100%; object-fit: cover; }

  .variant-picker--circle .variant-picker__swatch { border-radius: 50%; }
  .variant-picker--rounded .variant-picker__swatch { border-radius: 8px; }
  .variant-picker--square .variant-picker__swatch { border-radius: 0; }
  .variant-picker--pill .variant-picker__swatch,
  .variant-picker__swatch--pill { border-radius: 999px; }

  .variant-picker__input:checked + .variant-picker__swatch {
    border-color: var(--color-foreground);
    box-shadow: 0 0 0 1px var(--color-foreground);
  }

  /* Unavailable handling */
  .variant-picker--unavailable-strikethrough .variant-picker__swatch.is-unavailable { text-decoration: line-through; opacity: 0.5; }
  .variant-picker--unavailable-disabled .variant-picker__swatch.is-unavailable { opacity: 0.4; cursor: not-allowed; }
  .variant-picker--unavailable-hide .variant-picker__swatch.is-unavailable,
  .variant-picker--unavailable-hide option[data-unavailable] { display: none; }

  .variant-picker__select {
    padding: 10px 12px; border: 1px solid #d1d5db; border-radius: var(--style-border-radius-inputs, 6px);
    font-size: 0.95rem; min-width: 160px;
  }

  .visually-hidden, .variant-picker .visually-hidden {
    position: absolute; width: 1px; height: 1px; overflow: hidden; clip: rect(0 0 0 0); white-space: nowrap;
  }
{% endstylesheet %}

{% javascript %}
  if (!customElements.get('variant-picker')) {
    customElements.define('variant-picker', class extends HTMLElement {
      connectedCallback() {
        this._ctx = this.closest('product-context');
        if (!this._ctx) return;
        this._handler = this._onVariant.bind(this);
        this._ctx.addEventListener('variant:change', this._handler);
      }
      disconnectedCallback() {
        if (this._ctx && this._handler) this._ctx.removeEventListener('variant:change', this._handler);
      }
      _onVariant(event) {
        const variant = event.detail.variant;
        if (!variant) return;
        // Sync the "Selected: value" labels.
        this.querySelectorAll('[data-selected-value]').forEach((el) => {
          const pos = Number(el.dataset.selectedValue);
          const value = variant.options[pos - 1];
          if (value != null) el.textContent = value;
        });
      }
    });
  }
{% endjavascript %}

{% schema %}
{
  "name": "Variant picker",
  "settings": [
    { "type": "product", "id": "product", "label": "Product" },
    { "type": "header", "content": "Swatch type" },
    {
      "type": "select",
      "id": "swatch_type",
      "label": "Color swatch style",
      "default": "color",
      "options": [
        { "value": "image", "label": "Image" },
        { "value": "color", "label": "Color" },
        { "value": "pill", "label": "Pill" },
        { "value": "dropdown", "label": "Dropdown" }
      ]
    },
    {
      "type": "range",
      "id": "swatch_size",
      "label": "Swatch size",
      "min": 20, "max": 48, "step": 2, "unit": "px",
      "default": 28
    },
    {
      "type": "select",
      "id": "swatch_shape",
      "label": "Swatch shape",
      "default": "circle",
      "options": [
        { "value": "circle", "label": "Circle" },
        { "value": "square", "label": "Square" },
        { "value": "rounded", "label": "Rounded" }
      ]
    },
    { "type": "checkbox", "id": "show_selected_label", "label": "Show selected label", "default": true },
    {
      "type": "select",
      "id": "unavailable",
      "label": "Unavailable swatches",
      "default": "strikethrough",
      "options": [
        { "value": "strikethrough", "label": "Strikethrough" },
        { "value": "hide", "label": "Hide" },
        { "value": "disabled", "label": "Disabled" }
      ]
    },
    { "type": "header", "content": "Size option" },
    {
      "type": "select",
      "id": "size_type",
      "label": "Size picker type",
      "default": "pill",
      "options": [
        { "value": "pill", "label": "Pill" },
        { "value": "dropdown", "label": "Dropdown" }
      ]
    },
    { "type": "checkbox", "id": "show_size_guide", "label": "Show size guide", "default": true },
    { "type": "url", "id": "size_guide_url", "label": "Size guide URL" }
  ],
  "presets": [
    { "name": "Variant picker", "settings": { "product": "{{ closest.product }}" } }
  ]
}
{% endschema %}
