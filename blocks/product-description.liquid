{%- comment -%}
  Block: product-description
  Renders the product description (full or collapsed).
{%- endcomment -%}

{%- liquid
  assign p = block.settings.product
-%}

<div class="product-description{% if block.settings.collapse %} product-description--collapsed{% endif %}" {{ block.shopify_attributes }}>
  {%- if block.settings.heading != blank -%}
    <p class="product-description__heading">{{ block.settings.heading | escape }}</p>
  {%- endif -%}
  <div class="product-description__body rte">
    {%- if p.description != blank -%}
      {{ p.description }}
    {%- else -%}
      <p>Product description goes here.</p>
    {%- endif -%}
  </div>
  {%- if block.settings.collapse -%}
    <button type="button" class="product-description__toggle" data-desc-toggle aria-expanded="false">Read more</button>
  {%- endif -%}
</div>

{% stylesheet %}
  .product-description__heading { font-weight: 600; margin: 0 0 6px; }
  .product-description__body { line-height: 1.6; }
  .product-description__body > :first-child { margin-top: 0; }
  .product-description--collapsed .product-description__body {
    display: -webkit-box; -webkit-line-clamp: 4; -webkit-box-orient: vertical; overflow: hidden;
  }
  .product-description--collapsed.is-open .product-description__body {
    display: block; -webkit-line-clamp: none;
  }
  .product-description__toggle {
    margin-top: 6px; background: none; border: 0; padding: 0; cursor: pointer;
    text-decoration: underline; font-size: 0.9rem; color: inherit;
  }
{% endstylesheet %}

{% javascript %}
  document.querySelectorAll('[data-desc-toggle]').forEach((btn) => {
    if (btn._fpBound) return;
    btn._fpBound = true;
    btn.addEventListener('click', () => {
      const wrap = btn.closest('.product-description');
      const open = wrap.classList.toggle('is-open');
      btn.setAttribute('aria-expanded', open ? 'true' : 'false');
      btn.textContent = open ? 'Read less' : 'Read more';
    });
  });
{% endjavascript %}

{% schema %}
{
  "name": "Description / Text",
  "settings": [
    { "type": "product", "id": "product", "label": "Product" },
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "checkbox", "id": "collapse", "label": "Collapse long text", "default": false }
  ],
  "presets": [
    { "name": "Description / Text", "settings": { "product": "{{ closest.product }}" } }
  ]
}
{% endschema %}
