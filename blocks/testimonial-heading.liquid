{% doc %}
  Testimonial heading — a configurable heading. Used in the header and inside cards.

  @example
  {% content_for 'block', type: 'testimonial-heading', id: 'heading' %}
{% enddoc %}

{%- liquid
  assign s = block.settings
  assign tag = s.heading_size
-%}

<{{ tag }}
  class="ts-heading ts-heading--{{ s.alignment }}"
  style="
    --ts-heading-pt: {{ s.padding_top }}px;
    --ts-heading-pb: {{ s.padding_bottom }}px;
    {%- if s.color != blank -%}--ts-heading-color: {{ s.color }};{%- endif -%}
  "
  {{ block.shopify_attributes }}
>
  {{- s.heading -}}
</{{ tag }}>

{% stylesheet %}
  .ts-heading {
    margin: 0;
    padding-top: var(--ts-heading-pt, 0);
    padding-bottom: var(--ts-heading-pb, 0);
    color: var(--ts-heading-color, inherit);
  }
  .ts-heading--left   { text-align: left; }
  .ts-heading--center { text-align: center; }
  .ts-heading--right  { text-align: right; }
{% endstylesheet %}

{% schema %}
{
  "name": "Heading",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Client Says"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "h4", "label": "H4" },
        { "value": "h5", "label": "H5" },
        { "value": "h6", "label": "H6" }
      ],
      "default": "h2"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Alignment",
      "options": [
        { "value": "left",   "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right",  "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "color",
      "id": "color",
      "label": "Text color"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0, "max": 50, "step": 1, "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0, "max": 50, "step": 1, "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    { "name": "Heading" }
  ]
}
{% endschema %}
